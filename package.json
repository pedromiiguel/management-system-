{
  "name": "beverage-distributor",
  "private": true,
  "version": "0.1.0",
  "description": "Sistema de gestão para distribuidora de bebidas — produtos, PDV, financeiro e relatórios",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace packages/shared && npm run build --workspace apps/api && npm run build --workspace apps/web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run test --workspace apps/api",
    "test:e2e": "npm run test:e2e --workspace apps/e2e",
    "test:e2e:api": "npm run test:e2e --workspace apps/api",
    "db:migrate": "npm run db:migrate --workspace apps/api",
    "db:seed": "npm run db:seed --workspace apps/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.0"
  },
  "engines": {
    "node": ">=22"
  }
}
