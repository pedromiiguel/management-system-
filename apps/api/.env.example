# Conexão com o Postgres (docker compose sobe em localhost:5432)
DATABASE_URL="postgresql://beverage:beverage@localhost:5432/beverage?schema=public"
# Segredo do JWT — troque em produção
JWT_SECRET="change-me-in-production"
# Expiração do token
JWT_EXPIRES_IN="12h"
PORT=3000
# Origens autorizadas a chamar a API, separadas por vírgula (ex.: URL da Vercel).
# Vazio = reflete qualquer origem (use isso só em dev).
CORS_ORIGIN=
